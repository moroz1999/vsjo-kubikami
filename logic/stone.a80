                        module	stone
use_min_x                   equ	20

action
                            ld	a,(rooms.room_number_x)
                            cp	1
                            jr	nz,stone_false
                            ld	a,(rooms.room_number_y)
                            cp	1
                            jr	nz,stone_false
                            ld	a,(hero.hero_x)
                            cp	use_min_x
                            jr	c,stone_false

                            ld	d,12
                            ld	e,12
                            ld	hl,stone_anim
                            call	animate.start
                            call	apply_effect

                            ld	a,sounds.event_glass_break
                            call	sounds.play
                            call	hero.delete_item_in_pocket

                            ld	a,255
                            ret
stone_false
                            xor	a
                            ret

apply_effect
                            ld	a,1
                            ld	(logic.room_1_1.glass_broken),a
                            call	logic.room_1_1.activate_glass_route
                            ret

stone_anim
                            @animation	{
                            2       ;frames
                            0       ;current
                            20      ;delay
                            0       ;room_address
                            0       ;screen_address
                            0       ;room_x
                            0       ;room_y
                            8       ;width
                            8       ;height
                            }
sprites
animation_frame0
                            db	%00000000,%00000000,%00000000,%00000000,%00000000,%00000000,%00000000,%01001101
                            db	%00000000,%00000000,%00000000,%00000000,%00000000,%00000000,%00000000,%00000000
                            db	%00000000,%00000000,%00000000,%00000000,%00000000,%00000000,%01001101,%00000000
                            db	%00000000,%00000000,%00000000,%00000000,%01001101,%00000000,%00000000,%00000000
                            db	%00000000,%00000000,%00000000,%00000000,%00000000,%00000000,%00000000,%00000000
                            db	%00000000,%00000000,%00000000,%00000000,%00000000,%01001101,%00000000,%00000000
                            db	%00000000,%00000000,%00000000,%00000000,%00000000,%00000000,%00000000,%01001101
                            db	%00000000,%00000000,%00000000,%00000000,%00000000,%00000000,%00000000,%01001101
animation_frame1
                            db	%00000000,%00000000,%00000000,%00000000,%00000000,%00000000,%00000000,%01001101
                            db	%00000000,%00000000,%00000000,%00000000,%00000000,%00000000,%00000000,%00000000
                            db	%00000000,%00000000,%00000000,%00000000,%00000000,%00000000,%00000000,%00000000
                            db	%00000000,%00000000,%00000000,%00000000,%00000000,%00000000,%00000000,%00000000
                            db	%00000000,%00000000,%00000000,%00000000,%00000000,%00000000,%00000000,%00000000
                            db	%00000000,%00000000,%00000000,%00000000,%00000000,%00000000,%00000000,%00000000
                            db	%00000000,%00000000,%00000000,%00000000,%00000000,%00000000,%00000000,%01001101
                            db	%01001101,%00000000,%01001101,%00000000,%01001101,%00000000,%00000000,%01001101
                        endmodule
