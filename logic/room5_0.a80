                        module	room_5_0
on_enter
                            ld	a,(seeds_grown)
                            or	a
                            ret	z

                            ld	d,18
                            ld	e,8
                            ld	hl,logic.seeds.item_animation
                            call	animate.patch_last_frame
                            ret
seeds_grown                 db	0
                        endmodule
