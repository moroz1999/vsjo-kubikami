                            enemy	{
                            4,                  ; start room column
                            1,                  ; start room row
                            0,                  ; start cell column
                            19,                 ; start cell row
                            state_walk,         ; route behavior starts from neutral motion
                            80,                 ; free behavior choice pacing
                            80,                 ; first free behavior choice delay
                            direction_right,    ; initial route direction
                            8,                  ; route step pacing
                            8,                  ; first route step delay
                            0,                  ; can fall immediately
                            0,                  ; jump step
                            0,                  ; jump delay
                            simulation_mode_offline, ; refreshed during room init
                            behavior_route,     ; starts with route movement
                            route_3_1_right_entry, ; last route point
                            route_4_1_left_entry, ; target route point
                            offline_route_point_delay, ; offline route timer
                            0,                  ; route target search not attempted
                            220,                ; free-to-route switch delay
                            220                 ; first free-to-route switch timer
                            }

