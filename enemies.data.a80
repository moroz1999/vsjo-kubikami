initial_enemy_states
                ; room_x, room_y, x, y, state_timer, packed state/direction/behavior, route anchors
                            db	0,0,4,9,50
                            db	state_walk|(direction_right<<reset_direction_shift)|(behavior_free<<reset_behavior_shift)
                            dw	route_0_0_left,route_0_0_mid_left

                            db	3,1,7,19,40
                            db	state_stand|(direction_left<<reset_direction_shift)|(behavior_free<<reset_behavior_shift)
                            dw	route_3_1_bottom_fork,route_3_1_left_entry

                            db	5,1,8,19,80
                            db	state_walk|(direction_right<<reset_direction_shift)|(behavior_route<<reset_behavior_shift)
                            dw	route_5_1_bottom_left,route_5_1_bottom_fork

                            db	0,1,18,19,60
                            db	state_walk|(direction_left<<reset_direction_shift)|(behavior_route<<reset_behavior_shift)
                            dw	route_0_1_mid,route_0_1_left_mid

                            db	1,2,13,13,35
                            db	state_walk|(direction_right<<reset_direction_shift)|(behavior_route<<reset_behavior_shift)
                            dw	route_1_2_water_mid,route_1_2_water_mid_right

                            db	5,3,16,7,45
                            db	state_walk|(direction_left<<reset_direction_shift)|(behavior_route<<reset_behavior_shift)
                            dw	route_5_3_upper_mid,route_5_3_upper_mid_left

                            db	5,2,8,14,25
                            db	state_walk|(direction_right<<reset_direction_shift)|(behavior_route<<reset_behavior_shift)
                            dw	route_5_2_floor_mid,route_5_2_floor_right

                            db	0,3,12,16,55
                            db	state_walk|(direction_left<<reset_direction_shift)|(behavior_route<<reset_behavior_shift)
                            dw	route_0_3_center_floor,route_0_3_left_jump_left

                            db	0,0,27,9,15
                            db	state_stand|(direction_left<<reset_direction_shift)|(behavior_free<<reset_behavior_shift)
                            dw	route_0_0_right,route_0_0_mid_right
initial_enemy_states_end
                            assert	initial_enemy_states_end-initial_enemy_states=enemy_count*reset_record_size
