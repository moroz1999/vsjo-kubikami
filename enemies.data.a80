; Enemy drawing uses one shared flashing color for every enemy.
enemy_flash_colors          db	enemy_color1,enemy_color2
enemy_flash_color           db	enemy_color1

; Enemy random choices are shared by state and movement decisions.
random_seed                 db	random_seed_init

reset_state_mask            equ	%00000011
reset_direction_shift       equ	2
reset_behavior_shift        equ	3
reset_record_size           equ	10

reset_state
                ; Restore authored placement, motion, behavior, and route anchors.
                            ld	ix,enemies
                            ld	hl,initial_enemy_states
                            ld	b,enemy_count

reset_state_next
                            ld	a,(hl)
                            inc	hl
                            ld	(ix+enemy.room_x),a

                            ld	a,(hl)
                            inc	hl
                            ld	(ix+enemy.room_y),a

                            ld	a,(hl)
                            inc	hl
                            ld	(ix+enemy.x),a

                            ld	a,(hl)
                            inc	hl
                            ld	(ix+enemy.y),a

                            ld	a,(hl)
                            inc	hl
                            ld	(ix+enemy.state_timer),a

                            ld	a,(hl)
                            inc	hl
                            ld	c,a
                            and	reset_state_mask
                            ld	(ix+enemy.state),a

                            ld	a,c
                        dup	reset_direction_shift
                            rrca
                        edup
                            and	1
                            ld	(ix+enemy.direction),a

                            ld	a,c
                        dup	reset_behavior_shift
                            rrca
                        edup
                            and	1
                            ld	(ix+enemy.behavior_mode),a

                            ld	a,(hl)
                            inc	hl
                            ld	(ix+enemy.last_route_point_ptr),a
                            ld	a,(hl)
                            inc	hl
                            ld	(ix+enemy.last_route_point_ptr+1),a

                            ld	a,(hl)
                            inc	hl
                            ld	(ix+enemy.target_route_point_ptr),a
                            ld	a,(hl)
                            inc	hl
                            ld	(ix+enemy.target_route_point_ptr+1),a

                ; Derive mutable timers from each enemy's immutable profile.
                            ld	a,(ix+enemy.move_delay)
                            ld	(ix+enemy.move_timer),a

                            xor	a
                            ld	(ix+enemy.fall_timer),a
                            ld	(ix+enemy.jump_step),a
                            ld	(ix+enemy.jump_phase_delay),a
                            ld	(ix+enemy.route_target_search_done),a

                            ld	a,simulation_mode_offline
                            ld	(ix+enemy.simulation_mode),a

                            ld	a,offline_route_point_delay
                            ld	(ix+enemy.offline_route_timer),a

                            ld	a,(ix+enemy.behavior_switch_delay)
                            ld	(ix+enemy.behavior_switch_timer),a

                            ld	a,(ix+enemy.aggressive_stick_delay)
                            ld	(ix+enemy.aggressive_stick_timer),a

                            ld	a,(ix+enemy.behavior_mode)
                            ld	(ix+enemy.behavior_before_aggressive),a

                            ld	de,enemy_size
                            add	ix,de
                            djnz	reset_state_next

                            ld	a,random_seed_init
                            ld	(random_seed),a
                            ret

; Global enemy records define each enemy's starting room and behavior profile.
enemies
enemy_0
                            enemy	{
                            0,                  ; start room column
                            0,                  ; start room row
                            4,                  ; start cell column
                            9,                  ; start cell row
                            state_walk,         ; starts walking
                            100,                 ; behavior choice pacing
                            50,                 ; first behavior choice delay
                            direction_right,    ; initial patrol direction
                            10,                 ; patrol step pacing
                            10,                 ; first patrol step delay
                            0,                  ; can fall immediately
                            0,                  ; jump step
                            0,                  ; jump delay
                            simulation_mode_offline, ; refreshed during room init
                            behavior_free,      ; starts with free movement
                            route_0_0_left,     ; last route point
                            route_0_0_mid_left, ; target route point
                            offline_route_point_delay, ; offline route timer
                            0,                  ; route target search not attempted
                            150,                ; free-to-route switch delay
                            150,                ; first free-to-route switch timer
                            5,                  ; horizontal vision range
                            120,                ; aggressive stick delay
                            120,                ; aggressive stick timer
                            behavior_free       ; behavior restored after aggression
                            }

enemy_1
                            enemy	{
                            3,                  ; start room column
                            1,                  ; start room row
                            7,                  ; start cell column
                            19,                 ; start cell row
                            state_stand,        ; starts waiting
                            40,                 ; behavior choice pacing
                            40,                 ; first behavior choice delay
                            direction_left,     ; initial patrol direction
                            18,                 ; patrol step pacing
                            18,                 ; first patrol step delay
                            0,                  ; can fall immediately
                            0,                  ; jump step
                            0,                  ; jump delay
                            simulation_mode_offline, ; refreshed during room init
                            behavior_free,      ; starts with free movement
                            route_3_1_bottom_fork, ; last route point
                            route_3_1_left_entry, ; target route point
                            offline_route_point_delay, ; offline route timer
                            0,                  ; route target search not attempted
                            180,                ; free-to-route switch delay
                            180,                ; first free-to-route switch timer
                            9,                  ; horizontal vision range
                            225,                ; aggressive stick delay
                            225,                ; aggressive stick timer
                            behavior_free       ; behavior restored after aggression
                            }

